{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.38.5.1644",
      "templateHash": "9317765436813214613"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "A short name for the environment, such as dev, test, or prod. This helps you keep deployments organized."
      }
    },
    "location": {
      "type": "string",
      "allowedValues": [
        "eastus2"
      ],
      "metadata": {
        "description": "The Azure region where resources will be deployed. Locked to East US 2: it is the only region where every deployed model (model-router 2025-11-18, gpt-4.1, Phi-4-mini-reasoning) AND every Foundry feature the project uses is available — including the full evaluation suite (risk & safety evaluators, Groundedness Pro, and Protected Material, which is East US 2-only)."
      }
    },
    "cosmosAccountName": {
      "type": "string",
      "metadata": {
        "description": "The Cosmos DB account name. It must be globally unique across Azure and use only lowercase letters, numbers, and hyphens."
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "The SQL database name inside the Cosmos DB account. This is like a logical database for your app data."
      }
    },
    "containerName": {
      "type": "string",
      "metadata": {
        "description": "The container name inside the SQL database. This is where your items will be stored."
      }
    },
    "partitionKeyPath": {
      "type": "string",
      "defaultValue": "/tenantId",
      "metadata": {
        "description": "The partition key path for the container. This is the field Cosmos DB uses to spread data across partitions. Example: /tenantId"
      }
    },
    "throughput": {
      "type": "int",
      "defaultValue": 400,
      "metadata": {
        "description": "The throughput for the container in request units per second (RU/s). A small value like 400 is fine for development."
      }
    },
    "consistencyLevel": {
      "type": "string",
      "defaultValue": "Session",
      "allowedValues": [
        "BoundedStaleness",
        "ConsistentPrefix",
        "Session",
        "Strong",
        "Eventual"
      ],
      "metadata": {
        "description": "The consistency level for the account. Session is a good default for most apps."
      }
    },
    "projectName": {
      "type": "string",
      "metadata": {
        "description": "Foundry Project name - must be globally unique"
      }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "metadata": {
        "description": "Project public network access"
      }
    },
    "enableDataIsolation": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable data isolation for the project"
      }
    },
    "bingAccountName": {
      "type": "string",
      "defaultValue": "bing-grounding",
      "metadata": {
        "description": "Name for the Grounding with Bing Search account. Must be unique within the resource group."
      }
    },
    "searchServiceName": {
      "type": "string",
      "defaultValue": "cosmopilot-search",
      "metadata": {
        "description": "Name for the Azure AI Search service. Must be globally unique, 2-60 chars, lowercase letters, digits, and hyphens (no leading/trailing hyphen)."
      }
    },
    "searchServiceSku": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": [
        "free",
        "basic",
        "standard"
      ],
      "metadata": {
        "description": "Azure AI Search SKU. Basic is a good default for a demo; free allows only one per subscription."
      }
    },
    "searchIndexName": {
      "type": "string",
      "defaultValue": "knowledge-docs",
      "metadata": {
        "description": "Name of the search index that the knowledge-assistant queries."
      }
    },
    "searchLocation": {
      "type": "string",
      "defaultValue": "[parameters('location')]",
      "metadata": {
        "description": "Region for the Azure AI Search service. Defaults to the main location; override if that region is out of Search capacity."
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "projectFullName": "[format('{0}-{1}', parameters('projectName'), variables('uniqueSuffix'))]",
    "demoEnvironment": "demo",
    "modelDeploymentName": "gpt-4-1-nano",
    "modelType": "gpt-4.1-nano",
    "embeddingDeploymentName": "text-embedding-ada-002",
    "embeddingModelType": "text-embedding-ada-002",
    "searchFullName": "[format('{0}-{1}', parameters('searchServiceName'), variables('uniqueSuffix'))]",
    "modelRouterDeploymentName": "model-router",
    "modelRouterModelType": "model-router",
    "modelRouterModelVersion": "2025-11-18",
    "gpt41DeploymentName": "gpt-4.1",
    "gpt41ModelType": "gpt-4.1",
    "gpt41ModelVersion": "2025-04-14",
    "phiMiniReasoningDeploymentName": "Phi-4-mini-reasoning",
    "phiMiniReasoningModelType": "Phi-4-mini-reasoning",
    "phiMiniReasoningModelVersion": "1"
  },
  "resources": [
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-05-15",
      "name": "[parameters('cosmosAccountName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "tags": {
        "environment": "[parameters('environmentName')]"
      },
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableFreeTier": false,
        "consistencyPolicy": {
          "defaultConsistencyLevel": "[parameters('consistencyLevel')]"
        },
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ],
        "publicNetworkAccess": "enabled",
        "enableAutomaticFailover": false
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}', parameters('cosmosAccountName'), parameters('sqlDatabaseName'))]",
      "properties": {
        "resource": {
          "id": "[parameters('sqlDatabaseName')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}/{2}', parameters('cosmosAccountName'), parameters('sqlDatabaseName'), parameters('containerName'))]",
      "properties": {
        "resource": {
          "id": "[parameters('containerName')]",
          "partitionKey": {
            "paths": [
              "[parameters('partitionKeyPath')]"
            ],
            "kind": "Hash"
          },
          "indexingPolicy": {
            "indexingMode": "consistent",
            "automatic": true,
            "includedPaths": [
              {
                "path": "/*"
              }
            ],
            "excludedPaths": [
              {
                "path": "/\"_etag\"/?"
              }
            ]
          }
        },
        "options": {
          "throughput": "[parameters('throughput')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', parameters('cosmosAccountName'), parameters('sqlDatabaseName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[variables('projectFullName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "S0"
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[variables('projectFullName')]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]"
      },
      "tags": {
        "environment": "[variables('demoEnvironment')]"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('projectFullName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('modelDeploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": 50
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[variables('modelType')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('projectFullName'), variables('projectFullName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('embeddingDeploymentName'))]",
      "sku": {
        "name": "Standard",
        "capacity": 1
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[variables('embeddingModelType')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('modelDeploymentName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('modelRouterDeploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": 50
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[variables('modelRouterModelType')]",
          "version": "[variables('modelRouterModelVersion')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('embeddingDeploymentName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('gpt41DeploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": 50
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[variables('gpt41ModelType')]",
          "version": "[variables('gpt41ModelVersion')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('modelRouterDeploymentName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('projectFullName'), variables('phiMiniReasoningDeploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": 1
      },
      "properties": {
        "model": {
          "format": "Microsoft",
          "name": "[variables('phiMiniReasoningModelType')]",
          "version": "[variables('phiMiniReasoningModelVersion')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('gpt41DeploymentName'))]"
      ]
    },
    {
      "type": "Microsoft.Bing/accounts",
      "apiVersion": "2025-05-01-preview",
      "name": "[parameters('bingAccountName')]",
      "location": "global",
      "kind": "Bing.Grounding",
      "sku": {
        "name": "G1"
      },
      "tags": {
        "environment": "[variables('demoEnvironment')]"
      },
      "properties": {}
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects/connections",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}/{2}', variables('projectFullName'), variables('projectFullName'), 'binggrounding')]",
      "properties": {
        "category": "GroundingWithBingSearch",
        "target": "https://api.bing.microsoft.com/",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
          "key": "[listKeys(resourceId('Microsoft.Bing/accounts', parameters('bingAccountName')), '2025-05-01-preview').key1]"
        },
        "metadata": {
          "Type": "bing_grounding",
          "ApiType": "Azure",
          "ResourceId": "[resourceId('Microsoft.Bing/accounts', parameters('bingAccountName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Bing/accounts', parameters('bingAccountName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('projectFullName'), variables('projectFullName'))]"
      ]
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2024-06-01-preview",
      "name": "[variables('searchFullName')]",
      "location": "[parameters('searchLocation')]",
      "sku": {
        "name": "[parameters('searchServiceSku')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default",
        "publicNetworkAccess": "enabled",
        "authOptions": {
          "aadOrApiKey": {
            "aadAuthFailureMode": "http401WithBearerChallenge"
          }
        }
      },
      "tags": {
        "environment": "[variables('demoEnvironment')]"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects/connections",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}/{2}', variables('projectFullName'), variables('projectFullName'), 'aisearch')]",
      "properties": {
        "category": "CognitiveSearch",
        "target": "[format('https://{0}.search.windows.net', variables('searchFullName'))]",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
          "key": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('searchFullName')), '2024-06-01-preview').primaryKey]"
        },
        "metadata": {
          "Type": "azure_ai_search",
          "ApiType": "Azure",
          "ResourceId": "[resourceId('Microsoft.Search/searchServices', variables('searchFullName'))]",
          "ApiVersion": "2024-07-01"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('projectFullName'), variables('projectFullName'))]",
        "[resourceId('Microsoft.Search/searchServices', variables('searchFullName'))]"
      ]
    }
  ],
  "outputs": {
    "cosmosAccountName": {
      "type": "string",
      "value": "[parameters('cosmosAccountName')]"
    },
    "cosmosAccountEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), '2024-05-15').documentEndpoint]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[parameters('sqlDatabaseName')]"
    },
    "containerName": {
      "type": "string",
      "value": "[parameters('containerName')]"
    },
    "foundryResourceName": {
      "type": "string",
      "value": "[variables('projectFullName')]"
    },
    "foundryResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', variables('projectFullName'))]"
    },
    "foundryProjectName": {
      "type": "string",
      "value": "[variables('projectFullName')]"
    },
    "foundryProjectId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('projectFullName'), variables('projectFullName'))]"
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.services.ai.azure.com/api/projects/{1}', variables('projectFullName'), variables('projectFullName'))]"
    },
    "modelDeploymentName": {
      "type": "string",
      "value": "[variables('modelDeploymentName')]"
    },
    "modelDeploymentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('modelDeploymentName'))]"
    },
    "modelType": {
      "type": "string",
      "value": "[variables('modelType')]"
    },
    "embeddingDeploymentName": {
      "type": "string",
      "value": "[variables('embeddingDeploymentName')]"
    },
    "embeddingDeploymentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('embeddingDeploymentName'))]"
    },
    "embeddingModelType": {
      "type": "string",
      "value": "[variables('embeddingModelType')]"
    },
    "modelRouterDeploymentName": {
      "type": "string",
      "value": "[variables('modelRouterDeploymentName')]"
    },
    "modelRouterDeploymentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('modelRouterDeploymentName'))]"
    },
    "modelRouterModelType": {
      "type": "string",
      "value": "[variables('modelRouterModelType')]"
    },
    "gpt41DeploymentName": {
      "type": "string",
      "value": "[variables('gpt41DeploymentName')]"
    },
    "gpt41DeploymentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('gpt41DeploymentName'))]"
    },
    "gpt41ModelType": {
      "type": "string",
      "value": "[variables('gpt41ModelType')]"
    },
    "phiMiniReasoningDeploymentName": {
      "type": "string",
      "value": "[variables('phiMiniReasoningDeploymentName')]"
    },
    "phiMiniReasoningDeploymentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('projectFullName'), variables('phiMiniReasoningDeploymentName'))]"
    },
    "phiMiniReasoningModelType": {
      "type": "string",
      "value": "[variables('phiMiniReasoningModelType')]"
    },
    "bingAccountName": {
      "type": "string",
      "value": "[parameters('bingAccountName')]"
    },
    "bingConnectionName": {
      "type": "string",
      "value": "binggrounding"
    },
    "bingConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/projects/connections', variables('projectFullName'), variables('projectFullName'), 'binggrounding')]"
    },
    "searchServiceName": {
      "type": "string",
      "value": "[variables('searchFullName')]"
    },
    "searchServiceEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', variables('searchFullName'))]"
    },
    "searchConnectionName": {
      "type": "string",
      "value": "aisearch"
    },
    "searchConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/projects/connections', variables('projectFullName'), variables('projectFullName'), 'aisearch')]"
    },
    "searchIndexName": {
      "type": "string",
      "value": "[parameters('searchIndexName')]"
    }
  }
}