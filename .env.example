# =============================================================================
# Cosmopilot — Environment variables (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and replace the placeholder values:
#
#     cp .env.example .env          # macOS / Linux
#     Copy-Item .env.example .env   # Windows PowerShell
#
# `.env` is gitignored — never commit real endpoints, keys, or connection IDs.
# Every value below is a placeholder, not a real credential.
#
# Most agents authenticate with Azure via DefaultAzureCredential, so run
# `az login` first. API keys are only needed where explicitly noted.
# =============================================================================


# -----------------------------------------------------------------------------
# Azure AI Foundry project  (REQUIRED — used by every agent + the eval runner)
# -----------------------------------------------------------------------------
# Modern Foundry project endpoint includes the project path. You can also use
# the account-level form: https://<your-resource>.services.ai.azure.com
AZURE_AI_PROJECT_ENDPOINT="https://<your-resource>.services.ai.azure.com/api/projects/<your-project>"

# Default model deployment used when creating agents (hosted-agent).
AZURE_DEPLOYMENT_NAME="gpt-4o-mini"

# Model + agent identifiers used by the prompt / adventure-works agents.
MODEL_NAME="gpt-5.1"
AGENT_NAME="cosmopilot-assistant"


# -----------------------------------------------------------------------------
# Azure Cosmos DB  (REQUIRED for the data-insights + workflow agents)
# Auth is via DefaultAzureCredential — only the endpoint is needed here.
# -----------------------------------------------------------------------------
COSMOS_DB_ENDPOINT="https://<your-cosmos-account>.documents.azure.com:443/"
COSMOS_DB_DATABASE="cosmopilot"
COSMOS_DB_CONTAINER="conversations"


# -----------------------------------------------------------------------------
# Azure OpenAI — evaluation "judge" model  (REQUIRED for /evaluations)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT="https://<your-openai-resource>.openai.azure.com/"
AZURE_OPENAI_API_KEY="<your-azure-openai-api-key>"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"


# -----------------------------------------------------------------------------
# Azure AI project coordinates — safety evaluators / GroundednessPro
# (REQUIRED for the safety suite in /evaluations)
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_RESOURCE_GROUP="<your-resource-group>"
AZURE_AI_PROJECT_NAME="cosmopilot"


# =============================================================================
# Foundry agent TOOL connections  (OPTIONAL)
# -----------------------------------------------------------------------------
# Only set the variables for the tools you actually attach to an agent.
# Connection IDs from your Foundry project use the form:
#   /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<connection-name>
#
# Tools that need NO configuration: Code Interpreter, Function calling,
# basic Web Search (Bing), Tool Search.
# =============================================================================

# --- Azure AI Search (AzureAISearchAgentTool) — needs a Search connection ----
AZURE_AI_SEARCH_CONNECTION_ID="<your-ai-search-connection-id>"
AZURE_AI_SEARCH_ENDPOINT="https://<your-search-service>.search.windows.net"
AZURE_AI_SEARCH_INDEX_NAME="cosmopilot-index"
# Only needed if the connection uses key auth instead of managed identity:
# AZURE_AI_SEARCH_API_KEY="<your-search-query-or-admin-key>"

# --- Bing Grounding (BingGroundingAgentTool) — needs a Bing connection -------
AZURE_BING_CONNECTION_ID="<your-bing-grounding-connection-id>"

# --- Web Search / Custom Search (WebSearchPreviewTool) ----------------------
# Basic Bing web search needs no connection; Custom Search does:
BING_CUSTOM_SEARCH_CONNECTION_ID="<your-bing-custom-search-connection-id>"
BING_CUSTOM_SEARCH_CONFIG_NAME="<your-custom-config-name>"

# --- File Search (FileSearchTool) — needs a vector store --------------------
FILE_SEARCH_VECTOR_STORE_ID="<your-vector-store-id>"

# --- Agent Memory (MemorySearchTool) — needs an embedding deployment --------
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-large"
AGENT_MEMORY_STORE_ID="<your-agent-memory-store-id>"

# --- MCP server, remote (MCPTool) — auth optional --------------------------
MCP_SERVER_LABEL="cosmopilot-mcp"
MCP_SERVER_URL="https://<your-mcp-server>/mcp"
# MCP_SERVER_TOKEN="<optional-bearer-token>"

# --- Foundry Toolbox: shared tools (see agents/_shared) ----------------------
# The DRY "declare once, reuse everywhere" path. Agents read a single toolbox
# MCP endpoint that bundles code_interpreter + the Cosmos DB tools, so every
# agent style (hosted, multi-agent, prompt, workflow) shares the same tools.
#   - TOOLBOX_ENDPOINT: consumed by agents at runtime (do NOT prefix FOUNDRY_).
#   - COSMOS_MCP_SERVER_URL: where agents/_shared/cosmos_mcp_server.py is hosted;
#     referenced by agents/_shared/toolbox.yaml when the toolbox is created.
# Endpoint form: <project-endpoint>/toolboxes/<toolbox-name>/mcp?api-version=v1
TOOLBOX_ENDPOINT="https://<your-resource>.services.ai.azure.com/api/projects/<your-project>/toolboxes/cosmopilot-tools/mcp?api-version=v1"
COSMOS_MCP_SERVER_URL="https://<your-cosmos-mcp-server>/mcp"

# --- OpenAPI tool — auth conditional (anonymous / api-key / managed identity)-
OPENAPI_SPEC_URL="https://<your-api>/openapi.json"
# OPENAPI_CONNECTION_ID="<connection-id-if-the-api-requires-auth>"

# --- Agent-to-Agent, A2A (a2a_preview) — remote agent, auth optional --------
A2A_REMOTE_AGENT_ENDPOINT="https://<remote-agent-host>/a2a"
# A2A_CONNECTION_ID="<optional-connection-id>"

# --- Work IQ (preview) — needs an OAuth connection --------------------------
WORK_IQ_CONNECTION_ID="<your-work-iq-oauth-connection-id>"

# --- Fabric IQ (preview) — needs an OAuth connection ------------------------
FABRIC_IQ_CONNECTION_ID="<your-fabric-iq-oauth-connection-id>"
